{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Deck",
  "version": "0.1.0",
  "identifier": "app.deck.desktop",
  "build": {
    "frontendDist": "../dist-web",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Deck",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
